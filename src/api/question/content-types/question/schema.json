      "enum": ["fun", "deep", "memory", "future", "values", "daily"],
      "required": true
    },
    "scheduledDate": {
      "type": "date"
    },
    "tags": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}
