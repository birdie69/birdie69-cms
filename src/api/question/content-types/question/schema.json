{
  "kind": "collectionType",
  "collectionName": "questions",
  "info": {
    "singularName": "question",
    "pluralName": "questions",
    "displayName": "Question",
    "description": "Daily birdie69 couple question sourced from the content team."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
